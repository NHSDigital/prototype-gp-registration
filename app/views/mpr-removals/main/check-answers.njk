{% extends 'mpr/_layout.html' %}

{% set pageName = "Check your answers - Patient deductions - Manage patient registrations - NHS" %}

{% block beforeContent %}
  {{ backLink({
      href: "javascript:history.go(-1)",
      text: "Go back"
    }) 
  }}
{% endblock %}

{% block content %}

  {% set newRemoval = data.newRemoval or {} %}
  {% set incident = newRemoval.incident or {} %}
  {% set incidentDate = incident.date or {} %}
  {% set incidentTime = incident.time or {} %}
  {% set policeReport = newRemoval.policeReport or {} %}
  {% set policeReportDate = policeReport.date or {} %}

  {% set writtenWarningDetail = newRemoval.eightDayWarningDateFormatted %}
  {% set writtenWarningKey = "Date of written warning" %}
  {% if newRemoval.eightDayWarning != 'Yes' %}
    {% set writtenWarningDetail = '<ul class="nhsuk-list nhsuk-list--bullet">' %}
    {% for reason in (newRemoval.eightDayWarningReasons or []) %}
      {% set reasonText = reason.text or reason.value or reason %}
      {% if reasonText and reasonText != '_unchecked' %}
        {% set writtenWarningDetail = writtenWarningDetail + '<li>' + (reasonText | escape) + '</li>' %}
      {% endif %}
    {% endfor %}
    {% set writtenWarningDetail = writtenWarningDetail + '</ul>' %}
    {% set writtenWarningKey = "Reason(s) for no written warning" %}
  {% endif %}

  <h1 class="nhsuk-heading-xl">
    <span class="nhsuk-caption-l">
      Deduct a patient from your practice list
    </span>
    Check your answers
  </h1>

  <div class="nhsuk-grid-row">
    <div class="nhsuk-grid-column-two-thirds">
      <p>Check the information below is correct before you deduct the patient from your practice list.</p>

      {{ summaryList({
        card: {
          heading: "Patient details",
          headingSize: "m",
          actions: {
            items: [
              {
                text: "Change patient",
                href: "/mpr-removals/main/patient-search"
              }
            ]
          }
        },
        rows: [
          {
            key: {
              text: "Name"
            },
            value: {
              text: "Karen Francis"
            }
          },
          {
            key: {
              text: "Date of birth"
            },
            value: {
              text: "15 March 1984"
            }
          },
          {
            key: {
              text: "NHS number"
            },
            value: {
              text: data.search.nhsNumber
            }
          },
          {
            key: {
              text: "Home address postcode"
            },
            value: {
              text: "LS2 5ZN"
            }
          }
        ]
      }) }}

      {% if newRemoval.type == 'Immediate removal (Special allocation scheme)' %}

        {{ summaryList({
          card: {
            heading: "Removal information",
            headingSize: "m"
          },
          rows: [
            {
              key: { text: "Removal type" },
              value: { text: newRemoval.type }
            },
            {
              key: { text: "Reason for removal" },
              value: { text: newRemoval.deductionReason },
              actions: {
                items: [{ href: "/mpr-removals/main/removal-reason", text: "Change", visuallyHiddenText: "reason for removal" }]
              }
            },
            {
              key: { text: "Nature of incident" },
              value: { text: newRemoval.incidentType },
              actions: {
                items: [{ href: "/mpr-removals/main/sas/incident-type", text: "Change", visuallyHiddenText: "nature of incident" }]
              }
            },
            {
              key: { text: "Reported to the police" },
              value: { text: newRemoval.reportedToPolice },
              actions: {
                items: [{ href: "/mpr-removals/main/sas/police-report", text: "Change", visuallyHiddenText: "reported to the police" }]
              }
            }
          ]
        }) }}

        {% if newRemoval.reportedToPolice == 'Yes' %}
          {{ summaryList({
            card: {
              heading: "Police report details",
              headingSize: "m"
            },
            rows: [
              {
                key: { text: "Date reported to police" },
                value: { text: newRemoval.policeReportDateFormatted },
                actions: {
                  items: [{ href: "/mpr-removals/main/sas/police-details", text: "Change", visuallyHiddenText: "date reported to police" }]
                }
              },
              {
                key: { text: "Police Incident Number" },
                value: { text: policeReport.number },
                actions: {
                  items: [{ href: "/mpr-removals/main/sas/police-details", text: "Change", visuallyHiddenText: "police incident number" }]
                }
              }
            ]
          }) }}
        {% endif %}

        {{ summaryList({
          card: {
            heading: "Incident details",
            headingSize: "m"
          },
          rows: [
            {
              key: { text: "Date of incident" },
              value: { text: newRemoval.incidentDateFormatted },
              actions: {
                items: [{ href: "/mpr-removals/main/sas/incident-details", text: "Change", visuallyHiddenText: "date of incident" }]
              }
            },
            {
              key: { text: "Time of incident" },
              value: { text: incidentTime.hour + ':' + incidentTime.minute },
              actions: {
                items: [{ href: "/mpr-removals/main/sas/incident-details", text: "Change", visuallyHiddenText: "time of incident" }]
              }
            },
            {
              key: { text: "Location of incident" },
              value: { text: incident.location },
              actions: {
                items: [{ href: "/mpr-removals/main/sas/incident-details", text: "Change", visuallyHiddenText: "location of incident" }]
              }
            },
            {
              key: { text: "Description of incident" },
              value: { text: incident.description },
              actions: {
                items: [{ href: "/mpr-removals/main/sas/incident-details", text: "Change", visuallyHiddenText: "description of incident" }]
              }
            }
          ]
        }) }}

      {% else %}

        {{ summaryList({
          card: {
            heading: "Deduction information",
            headingSize: "m"
          },
          rows: [
            {
              key: { text: "Deduction type" },
              value: { text: newRemoval.type }
            },
            {
              key: { text: "Reason for deduction" },
              value: { text: newRemoval.deductionReason },
              actions: {
                items: [{ href: "/mpr-removals/main/removal-reason", text: "Change", visuallyHiddenText: "deduction reason" }]
              }
            },
            {
              key: { text: "Written warning given within past 12 months" },
              value: { text: newRemoval.eightDayWarning },
              actions: {
                items: [{ href: "/mpr-removals/main/8-day/warning", text: "Change", visuallyHiddenText: "written warning given within past 12 months" }]
              }
            },
            {
              key: { text: writtenWarningKey },
              value: { html: writtenWarningDetail },
              actions: {
                items: [{ href: "/mpr-removals/main/8-day/warning", text: "Change", visuallyHiddenText: writtenWarningKey }]
              }
            }
          ]
        }) }}

      {% endif %}

      <form method="post" action="/mpr-removals/main/confirmation">
        {{ button({
          text: 'Confirm and deduct patient' 
        }) }}
      </form>
    </div>
  </div>

{% endblock %}